# ── Anthropic (Claude API) ────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Model to use for live signal analysis
# claude-haiku-4-5-20251001   → fast & cheap  (~$0.001 per signal)
# claude-sonnet-4-6           → best quality  (~$0.01  per signal)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── Trading ───────────────────────────────────────────────────────────────────
# Default symbol for live analysis
SYMBOL=SPY

# ── Paths (optional overrides) ────────────────────────────────────────────────
TRADE_JOURNAL_PATH=memory/trades.jsonl
ML_MODEL_PATH=models/signal_scorer.pkl
